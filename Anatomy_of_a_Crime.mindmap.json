              },
              {
                "id": "node_118",
                "text": "Proximate Cause - was it foreseeable?",
                "collapsed": true,
                "children": [
                  {
                    "id": "node_119",
                    "text": "Intervening Cause Analysis",
                    "collapsed": false,
                    "children": [
                      {
                        "id": "node_120",
                        "text": "Responsive intervening Causes. D is still liable",
                        "collapsed": false,
                        "children": []
                      },
                      {
                        "id": "node_121",
                        "text": "Coincidental - may break the chain",
                        "collapsed": false,
                        "children": []
                      },
                      {
                        "id": "node_122",
                        "text": "De Minimus Contribution - D's role was trivial",
                        "collapsed": false,
                        "children": []
                      },
                      {
                        "id": "node_123",
                        "text": "Intended consequences doctirine - D is still liable even though the chain was unexpected.",
                        "collapsed": false,
                        "children": []
                      },
                      {
                        "id": "node_124",
                        "text": "Apparent Safety Doctrine",
                        "collapsed": false,
                        "children": []
                      },
                      {
                        "id": "node_125",
                        "text": "Free, deliberate, informaed human intervention - 3rd party's voluntary choice breaks the chain.",
                        "collapsed": false,
                        "children": []
                      }
